# Storage is SQLite via libSQL. Local dev needs nothing: it writes a file at
# apps/server/data/boards.db by default. Override the file if you like:
# DATABASE_URL=file:./data/boards.db

# Deploying serverless (Vercel) has no durable disk, so use Turso instead. When
# TURSO_DATABASE_URL is set it wins over the local file.
# TURSO_DATABASE_URL=libsql://your-db.turso.io
# TURSO_AUTH_TOKEN=your-token

# PORT=8787
